# =============================================================================
# DATABASE CONFIG
# =============================================================================
# PostgreSQL connection used by ETL + API ingestion + scheduler
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=financial_db
DATABASE_URL=postgresql+psycopg2://admin:password123@db:5432/financial_db


# =============================================================================
# DIRECTORY PATHS (Docker container paths)
# =============================================================================
SCHEMA_DIR=/app/schemas
DATA_DIR=/app/data
SQL_DIR=/app/sql


# =============================================================================
# ACCORD API CONFIG
# =============================================================================
# Real production token from Accord
ACCORD_API_TOKEN=YOUR_REAL_ACCORD_TOKEN_HERE

# Optional manual override date for testing
# Format: DDMMYYYY
# Leave blank for today's date
API_DATE=


# =============================================================================
# ETL FULL LOAD CONFIG
# =============================================================================
# Batch size for full dump + API chunk processing
ETL_BATCH_SIZE=50000

# Delay between chunks (seconds)
ETL_BATCH_SLEEP=0

# Safety controls for schema reset
ETL_RECREATE_SCHEMA=false
ETL_FORCE_RESET=false

# Retry transient DB failures during full ETL
ETL_TABLE_RETRIES=3

# Commit each chunk independently
ETL_CHUNK_COMMIT_MODE=true


# =============================================================================
# API INGESTION HARDENING
# =============================================================================
# Skip already successful feed/date unless force=true
ENABLE_IDEMPOTENCY=true

# Retry unresolved rejected rows
ENABLE_REJECTED_RETRY=true

# Max retries before row remains unresolved
MAX_REJECTED_ROW_RETRY=5

# Allow mass delete anomaly (>40% D flags)
ALLOW_MASS_DELETE=false

# Consecutive API failure circuit breaker threshold
MAX_CONSECUTIVE_FAILURES=3


# =============================================================================
# API CLIENT RETRY CONFIG
# =============================================================================
API_MAX_RETRIES=3
API_RETRY_BACKOFF_1=2
API_RETRY_BACKOFF_2=5
API_RETRY_BACKOFF_3=10
API_TIMEOUT_SECONDS=60


# =============================================================================
# SCHEDULER CONFIG
# =============================================================================
TIMEZONE=Asia/Kolkata

# Company Master intraday
COMPANY_MASTER_HOURS=10,13,16,22
COMPANY_MASTER_MINUTE=35

# Results hourly
RESULTS_START_HOUR=9
RESULTS_END_HOUR=23
RESULTS_MINUTE=5
RESULTS_FINAL_HOUR=23
RESULTS_FINAL_MINUTE=30

# EOD feeds
EOD_HOUR=22
EOD_MINUTE=45

# EOD retry
EOD_RETRY_HOUR=23
EOD_RETRY_MINUTE=30


# =============================================================================
# ALERTING CONFIG (Skeleton now, future Slack/Telegram)
# =============================================================================
ENABLE_ALERTS=true

# Optional future integrations
ALERT_EMAIL=
ALERT_SLACK_WEBHOOK=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=


# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_RAW_PAYLOAD=true
MASK_API_TOKEN_IN_LOGS=true


# =============================================================================
# DOCKER / APP MODE
# =============================================================================
APP_ENV=production

# Modes:
# manual
# scheduler
# backfill
RUN_MODE=scheduler
